# Скопируй в deploy/prod-up.env и поправь под свой сервер.

# Корень фронта Lampa
FRONT_DIR="/var/www/USER/data/www/example.com/lampa-source"

# Куда публиковать собранный статический фронт.
# Если FastPanel смотрит прямо в build/github/lampa, оставь пусто.
FRONT_PUBLISH_DIR="/var/www/USER/data/www/example.com/public_html"

# Обычный Laravel backend
BACK_DIR="/var/www/USER/data/www/example.com/lampa-source/cub"
BACK_ENV_FILE="/var/www/USER/data/www/example.com/lampa-source/cub/.env"

# Если на сервере npm ci не подходит, замени на npm install
FRONT_NODE_INSTALL_CMD="npm ci"
BACK_NODE_INSTALL_CMD="npm ci"

# Если на сервере нужен конкретный php/composer
BACK_PHP_BIN="php"
BACK_COMPOSER_BIN="composer"
BACK_COMPOSER_INSTALL_CMD="composer install --no-dev --optimize-autoloader"
BACK_BUILD_CMD="npm run build"

# Обычно нужно оставить true
BACK_RUN_MIGRATIONS="true"
BACK_RUN_CACHE="true"
BACK_RUN_STORAGE_LINK="true"

# Права
SET_PERMISSIONS="false"
DEPLOY_USER="www-data"
DEPLOY_GROUP="www-data"

# Если хочешь, чтобы скрипт сам поставил и перезапустил systemd-сервис websocket
INSTALL_SOCKET_SERVICE="false"
SOCKET_SERVICE_NAME="timeline-socket"
SOCKET_SERVICE_USER="www-data"
SOCKET_SERVICE_GROUP="www-data"
SOCKET_HOST="127.0.0.1"
SOCKET_PORT="9001"

# Если в корне проекта есть supervisor.conf, скрипт попробует использовать Supervisor
SUPERVISOR_CONF_FILE="/var/www/USER/data/www/example.com/lampa-source/supervisor.conf"
SUPERVISORCTL_BIN="supervisorctl"
SUPERVISOR_PROGRAM_NAME="timeline-socket"

# Если sudo лежит не там
SUDO_BIN="sudo"
